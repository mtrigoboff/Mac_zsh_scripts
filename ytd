# download YouTube audio or video

if [[ $# == 2 ]]; then
    if [[ $1 == '-a' ]]; then
        # download audio from a YouTube video as a WAV file
        yt-dlp -x --audio-format wav --audio-quality 0 $2
    elif [[ $1 == '-v' ]]; then
        # download a YouTube video as an MP4 file
        yt-dlp -f "bv+ba/b" --remux-video mp4 $2
    else
        echo 'options are: -a for audio, -v for video'
    fi
else
    echo 'usage: ytd [-a|-v] <YouTube URL wrapped in single quotes>'
fi
